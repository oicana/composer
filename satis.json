{
    "name": "oicana/packages",
    "homepage": "https://composer.oicana.com",
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/oicana/oicana",
            "name": "oicana/oicana-packages"
        }
    ],
    "require": {
        "oicana/oicana": "*",
        "oicana/installer": "*"
    },
    "require-dependencies": true,
    "require-dev-dependencies": false,
    "archive": {
        "directory": "dist",
        "format": "tar",
        "skip-dev": false
    }
}
